# HRMS Backend Environment Configuration
DATABASE_URL=sqlite+aiosqlite:///./hrms.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hrms_db

SECRET_KEY=hrms-super-secret-jwt-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

APP_NAME=HRMS Enterprise
APP_VERSION=1.0.0
DEBUG=true

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
